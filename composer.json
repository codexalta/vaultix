{
    "name": "codexalta/vaultix",
    "description": "A dynamic Backup System for Laravel with Admin Dashboard, Smart Storage Projection, and Multi-provider Support.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Codexalta",
            "email": "codexalta@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0",
        "spatie/laravel-backup": "^9.0|^10.0",
        "masbug/flysystem-google-drive-ext": "^2.5",
        "league/flysystem-aws-s3-v3": "^3.0",
        "league/flysystem-sftp-v3": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Codexalta\\Vaultix\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codexalta\\Vaultix\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codexalta\\Vaultix\\VaultixServiceProvider"
            ]
        }
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "fakerphp/faker": "^1.9.1",
        "mockery/mockery": "^1.4.4"
    },
    "prefer-stable": true
}
